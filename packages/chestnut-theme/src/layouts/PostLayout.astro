---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/shared/TOC.astro';
import PageNav from '../components/shared/PageNav.astro';
import { formatDate } from '../utils/date';

interface SidebarTag {
  name: string;
  count: number;
}

interface Props {
  // Site-wide config (optional — fallback to Astro.locals.site)
  siteTitle?: string;
  siteDescription?: string;
  nav?: Array<{ href: string; label: string }>;
  themes?: Array<{ id: string; name: string }>;
  defaultTheme?: string;
  author?: string;
  icp?: string;
  icpUrl?: string;
  // Post-specific
  sidebar?: boolean;
  sidebarData: {
    avatar: string;
    author: string;
    bio: string;
    postsCount: number;
    tags: SidebarTag[];
    tagCount: number;
    githubUrl?: string;
  };
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readingTime?: number;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
  // 上下篇导航
  prev?: { title: string; slug: string };
  next?: { title: string; slug: string };
}

const {
  sidebar = true,
  sidebarData,
  title, description, pubDate, tags = [], readingTime, headings = [],
  prev, next,
} = Astro.props;



const routes = Astro.locals.site?.routes;
const blogPrefix = routes?.blog?.prefix ?? '/blog';

const dateStr = formatDate(pubDate);
---

<BaseLayout
  title={`${title} - ${Astro.locals.site?.title ?? Astro.props.siteTitle ?? ''}的博客`}
  description={description}
  sidebar={sidebar}
  sidebarData={sidebarData}
>
  <div class="post-page">
      <aside class="post-toc" id="post-toc">
        <TOC headings={headings} />
      </aside>

    <article class="post-article">
      <a href="{blogPrefix}" class="back-link">&larr; 返回文章列表</a>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <time>{dateStr}</time>
          {readingTime && <span>阅读大约需要 {readingTime} 分钟</span>}
          {tags.length > 0 && (
            <div class="tags">
              {tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </header>
      <div class="prose">
        <slot />
      </div>
      <PageNav prev={prev} next={next} prefix={blogPrefix} />
    </article>
  </div>
</BaseLayout>

<button class="post-toc-toggle" id="post-toc-toggle" aria-label="切换目录">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="15" y2="12"/>
        <line x1="3" y1="18" x2="18" y2="18"/>
      </svg>
    </button>

<style>
  :global(.layout-wrapper) {
    max-width: 1320px;
    margin: 0 auto;
    padding: 0;
  }

  .post-page {
    min-height: calc(100vh - var(--header-height));
    padding-left: 220px; /* 200px TOC + 20px 间距 */
  }

  .post-article {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }

  /* ============================================
     TOC（左侧，fixed 定位，不影响文档流）
     ============================================ */
  .post-toc {
    position: fixed;
    top: calc(var(--header-height) + 24px);
    left: 0.25rem;
    width: 200px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding: 0.5rem 0.75rem;
    border-right: 1px solid var(--border);
  }

  /* ============================================
     移动端：TOC 悬浮按钮
     ============================================ */
  .post-toc-toggle {
    display: none;
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    color: var(--fg);
    cursor: pointer;
    box-shadow: var(--shadow-md);
    z-index: 210;
    transition: all 0.2s ease;
  }

  .post-toc-toggle:hover {
    background: var(--accent-light);
    color: var(--accent);
  }

  .post-toc-toggle.open {
    background: var(--accent);
    color: #fff;
  }

  .tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    padding: 0.12rem 0.5rem;
    background: var(--accent-light);
    color: var(--fg);
    border-radius: 999px;
    font-weight: 500;
  }



  /* ============================================
     响应式
     ============================================ */

  /* 平板端：隐藏左侧 TOC */
  @media (max-width: 1200px) {
    .post-page {
      padding-left: 0;
    }

    .post-toc {
      display: none;
    }

    .post-toc-toggle {
      display: flex;
    }
  }

  /* TOC 全屏浮层（点击按钮后） */
  @media (max-width: 1200px) {
    .post-toc.is-overlay {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 200;
      background: var(--card-bg);
      padding: 4rem 1.5rem 2rem;
      width: 100%;
      max-height: none;
      overflow-y: auto;
      border-right: none;
      border-top: 1px solid var(--border);
    }
  }

  /* 手机端：文章 flex 变列 */
  @media (max-width: 768px) {
    .post-page {
      flex-direction: column;
    }
  }
</style>

<script>
  let _tocClick: (() => void) | null = null;
  let _tocDocClick: ((e: Event) => void) | null = null;

  function initPostToc() {
    const toggle = document.getElementById('post-toc-toggle');
    const toc = document.getElementById('post-toc');

    if (!toggle || !toc) return;

    if (_tocClick) toggle.removeEventListener('click', _tocClick);
    if (_tocDocClick) document.removeEventListener('click', _tocDocClick);

    _tocClick = () => {
      toc.classList.toggle('is-overlay');
      toggle.classList.toggle('open');
    };

    _tocDocClick = (e) => {
      if (!toc.contains(e.target as Node) && !toggle.contains(e.target as Node)) {
        toc.classList.remove('is-overlay');
        toggle.classList.remove('open');
      }
    };

    toggle.addEventListener('click', _tocClick);
    document.addEventListener('click', _tocDocClick);
  }

  initPostToc();

  document.addEventListener('astro:after-swap', () => {
    initPostToc();
  });
</script>