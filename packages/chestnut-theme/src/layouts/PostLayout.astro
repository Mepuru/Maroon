---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/shared/TOC.astro';
import { formatDate } from '../utils/date';

interface SidebarTag {
  name: string;
  count: number;
}

interface NavItem {
  href: string;
  label: string;
}

interface ThemeItem {
  id: string;
  name: string;
}

interface Props {
  // BaseLayout site-wide config
  siteTitle: string;
  siteDescription: string;
  nav: NavItem[];
  themes: ThemeItem[];
  defaultTheme: string;
  author: string;
  icp?: string;
  icpUrl?: string;
  // Sidebar
  sidebar: true;
  sidebarData: {
    avatar: string;
    author: string;
    bio: string;
    postsCount: number;
    tags: SidebarTag[];
    tagCount: number;
    githubUrl?: string;
  };
  // Post-specific
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readingTime?: number;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const {
  siteTitle, siteDescription, nav, themes, defaultTheme,
  author, icp, icpUrl,
  sidebarData,
  title, description, pubDate, tags = [], readingTime, headings = [],
} = Astro.props;

const dateStr = formatDate(pubDate);
---

<BaseLayout
  {siteTitle} {siteDescription} {nav} {themes} {defaultTheme}
  {author} {icp} {icpUrl}
  title={`${title} - ${siteTitle}的博客`}
  description={description}
  sidebar={true}
  sidebarData={sidebarData}
>
  <div class="post-page">
    {headings.length > 0 && <TOC headings={headings} />}

    <article class="post-article">
      <a href="/blog" class="back-link">&larr; 返回文章列表</a>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <time>{dateStr}</time>
          {readingTime && <span>阅读大约需要 {readingTime} 分钟</span>}
          {tags.length > 0 && (
            <div class="tags">
              {tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
  </div>
</BaseLayout>

<style>
  .post-page {
    display: flex;
    gap: 2rem;
  }

  .post-article {
    flex: 1;
    min-width: 0;
  }

  .tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    padding: 0.12rem 0.5rem;
    background: var(--accent-light);
    color: var(--fg);
    border-radius: 999px;
    font-weight: 500;
  }

  @media (max-width: 1200px) {
    .post-page {
      flex-direction: column;
    }
  }
</style>