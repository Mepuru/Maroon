---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';
import Sidebar from '../components/shared/Sidebar.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface SidebarTag {
  name: string;
  count: number;
}

interface NavItem {
  href: string;
  label: string;
}

interface ThemeItem {
  id: string;
  name: string;
}

interface Props {
  // Site-wide config (all optional — fallback to Astro.locals.site)
  siteTitle?: string;
  siteDescription?: string;
  nav?: NavItem[];
  themes?: ThemeItem[];
  defaultTheme?: string;
  author?: string;
  icp?: string;
  icpUrl?: string;
  // Page-level
  title?: string;
  description?: string;
  // Sidebar (optional)
  sidebar?: boolean;
  sidebarData?: {
    avatar: string;
    author: string;
    bio: string;
    postsCount: number;
    tags: SidebarTag[];
    tagCount: number;
    githubUrl?: string;
  };
}

// 优先从 Astro.locals.site 读取全局配置（middleware 注入），props 优先级更高
const ctx = Astro.locals.site;

const siteTitle = Astro.props.siteTitle ?? ctx?.title ?? '';
const siteDescription = Astro.props.siteDescription ?? ctx?.description ?? '';
const nav = Astro.props.nav ?? ctx?.nav ?? [];
const themes = Astro.props.themes ?? ctx?.themes ?? [];
const defaultTheme = Astro.props.defaultTheme ?? ctx?.defaultTheme ?? 'cream';
const author = Astro.props.author ?? ctx?.author ?? '';
const icp = Astro.props.icp ?? ctx?.footer?.icp;
const icpUrl = Astro.props.icpUrl ?? ctx?.footer?.icpUrl;

const title = Astro.props.title ?? siteTitle;
const description = Astro.props.description ?? siteDescription;
const { sidebar = false, sidebarData } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem('theme') || defaultTheme;
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <div class="print-meta" style="display:none">{siteTitle} | {Astro.url.href}</div>
    <Header siteTitle={siteTitle} nav={nav} themes={themes} />
    <div class:list={['layout-wrapper', { wide: !sidebar }]}>
      <main class="main-content">
        <slot />
      </main>
      {sidebar && sidebarData && (
        <Sidebar
          avatar={sidebarData.avatar}
          author={sidebarData.author}
          bio={sidebarData.bio}
          postsCount={sidebarData.postsCount}
          tags={sidebarData.tags}
          tagCount={sidebarData.tagCount}
          githubUrl={sidebarData.githubUrl}
        />
      )}
    </div>
    <Footer {author} {icp} {icpUrl} />
    <Search />
    <script>
      document.addEventListener('astro:after-swap', () => {
        const theme = localStorage.getItem('theme');
        if (theme) {
          document.documentElement.setAttribute('data-theme', theme);
        }
      });

      window.addEventListener('beforeprint', () => {
        document.querySelectorAll('details').forEach(el => el.setAttribute('open', ''));
      });
      window.addEventListener('afterprint', () => {
        document.querySelectorAll('details').forEach(el => el.removeAttribute('open'));
      });
    </script>
  </body>
</html>