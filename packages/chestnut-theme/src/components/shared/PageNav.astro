---
interface NavItem {
  title: string;
  slug: string;
}

interface Props {
  prev?: NavItem | null;
  next?: NavItem | null;
  prefix: string;
}

const { prev, next, prefix } = Astro.props;

const truncateTitle = (s: string, max = 24) =>
  s.length > max ? s.slice(0, max) + '…' : s;
---

{(prev || next) && (
  <nav class="page-nav">
    {prev ? (
      <a href={`${prefix}/${prev.slug}`} class="page-nav-link">
        <span class="page-nav-label">&larr; 上一篇</span>
        <span class="page-nav-title">{truncateTitle(prev.title)}</span>
      </a>
    ) : <span />}
    {next ? (
      <a href={`${prefix}/${next.slug}`} class="page-nav-link page-nav-next">
        <span class="page-nav-label">下一篇 &rarr;</span>
        <span class="page-nav-title">{truncateTitle(next.title)}</span>
      </a>
    ) : <span />}
  </nav>
)}

<style>
  .page-nav {
    display: flex;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .page-nav-link {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .page-nav-link:hover {
    border-color: var(--accent);
    background: var(--accent-light);
  }

  .page-nav-next {
    text-align: right;
  }

  .page-nav-label {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .page-nav-title {
    font-size: 0.9rem;
    color: var(--fg);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  @media (max-width: 768px) {
    .page-nav {
      flex-direction: column;
    }
  }
</style>
