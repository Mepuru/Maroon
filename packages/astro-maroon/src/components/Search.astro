---
---

<style>
  @import './Search.css';
</style>

<div id="search-modal" class="search-modal" onclick="if(event.target===this) this.classList.remove('open')">
  <div class="search-box">
    <input type="text" id="search-input" class="search-input" placeholder="搜索文章..." />
    <div id="search-results" class="search-results"></div>
  </div>
</div>

<script is:inline>
  let pagefind;

  async function initSearch() {
    try {
      pagefind = await import('/pagefind/pagefind.js');
      await pagefind.options({ excerptLength: 30 });
    } catch {
      console.warn('Pagefind 未加载，搜索功能不可用（dev 模式正常）');
    }
  }

  initSearch();

  const input = document.getElementById('search-input');
  const results = document.getElementById('search-results');

  input?.addEventListener('input', async (e) => {
    const query = e.target.value.trim();
    if (!query || !pagefind) {
      results.innerHTML = '';
      return;
    }

    const search = await pagefind.debouncedSearch(query);
    if (!search) return;

    const items = search.results;
    if (items.length === 0) {
      results.innerHTML = '<div class="search-result-item"><span class="title" style="color:var(--muted)">没有找到相关文章</span></div>';
      return;
    }

    const html = await Promise.all(
      items.slice(0, 10).map(async (item) => {
        try {
          const data = await item.data();
          return `
            <div class="search-result-item" onclick="window.location.href='${data.url}'">
              <div class="title">${data.meta?.title || data.url}</div>
              <div class="excerpt">${data.excerpt}</div>
            </div>
          `;
        } catch {
          return '';
        }
      })
    );

    results.innerHTML = html.join('');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('search-modal')?.classList.remove('open');
    }
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      document.getElementById('search-modal')?.classList.add('open');
      input?.focus();
    }
  });
</script>
