---
import { generatePath } from '../../utils/generate-path';

interface DocNavItem {
  slug: string;
  title: string;
}

interface DocCategory {
  name: string;
  docs: DocNavItem[];
}

interface Props {
  currentSlug?: string;
  categories: DocCategory[];
  totalCount: number;
  uncategorized?: DocNavItem[];
  /** 文档 URL pattern，默认 /docs/[slug] */
  docPattern?: string;
}

const { currentSlug, categories, totalCount, uncategorized = [], docPattern = '/docs/[slug]' } = Astro.props;
---

<aside class="docs-sidebar" id="docs-sidebar">
  <div class="sidebar-header">
    <h3 class="sidebar-title">文档</h3>
    <p class="sidebar-count">共 {totalCount} 篇</p>
  </div>

  <nav class="sidebar-nav">
    {categories.map((cat) => (
      <details class="category-group" open>
        <summary class="category-name">
          {cat.name}
          <span class="category-count">{cat.docs.length}</span>
        </summary>
        <div class="category-items">
          {cat.docs.map((doc) => (
            <a
              href={generatePath(docPattern, { slug: doc.slug })}
              class:list={['sidebar-link', { active: currentSlug === doc.slug }]}
              title={doc.title}
            >
              {doc.title}
            </a>
          ))}
        </div>
      </details>
    ))}

    {uncategorized.length > 0 && categories.length > 0 && (
      <details class="category-group" open>
        <summary class="category-name">
          未分类
          <span class="category-count">{uncategorized.length}</span>
        </summary>
        <div class="category-items">
          {uncategorized.map((doc) => (
            <a
              href={generatePath(docPattern, { slug: doc.slug })}
              class:list={['sidebar-link', { active: currentSlug === doc.slug }]}
              title={doc.title}
            >
              {doc.title}
            </a>
          ))}
        </div>
      </details>
    )}

    {uncategorized.length > 0 && categories.length === 0 && (
      uncategorized.map((doc) => (
        <a
          href={generatePath(docPattern, { slug: doc.slug })}
          class:list={['sidebar-link', { active: currentSlug === doc.slug }]}
          title={doc.title}
        >
          {doc.title}
        </a>
      ))
    )}
  </nav>
</aside>

<style>
  .docs-sidebar {
    position: fixed;
    top: var(--header-height);
    left: 0;
    width: var(--sidebar-width);
    height: calc(100vh - var(--header-height));
    overflow-y: auto;
    background: var(--bg);
    border-right: 1px solid var(--border);
    padding: 2rem 0;
    z-index: 1;
  }

  .sidebar-header {
    margin-bottom: 1.5rem;
    padding: 0 1rem 1rem;
    border-bottom: 1px dashed var(--border);
  }

  .sidebar-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--fg);
    margin: 0 0 0.25rem 0;
  }

  .sidebar-count {
    font-size: 0.8rem;
    color: var(--muted);
    margin: 0;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0 1rem;
  }

  /* 分类组 */
  .category-group {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    margin-bottom: 0.75rem;
    overflow: hidden;
  }

  .category-name {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--fg);
    cursor: pointer;
    user-select: none;
    list-style: none;
    background: var(--bg-secondary);
    border-bottom: 1px solid transparent;
    transition: background 0.2s ease;
  }

  .category-name::-webkit-details-marker {
    display: none;
  }

  .category-name::before {
    content: '▸';
    display: inline-block;
    margin-right: 0.5rem;
    font-size: 0.7rem;
    transition: transform 0.2s ease;
    color: var(--muted);
  }

  .category-group[open] .category-name::before {
    transform: rotate(90deg);
  }

  .category-group[open] .category-name {
    border-bottom-color: var(--border);
  }

  .category-name:hover {
    background: var(--accent-light);
  }

  .category-count {
    font-size: 0.7rem;
    color: var(--muted);
    font-weight: 400;
    background: var(--bg);
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
  }

  .category-items {
    display: flex;
    flex-direction: column;
    padding: 0.25rem 0;
  }

  /* 文档链接 */
  .sidebar-link {
    display: block;
    padding: 0.5rem 1rem;
    color: var(--fg);
    opacity: 0.75;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    border-left: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .sidebar-link:hover {
    color: var(--accent);
    background: var(--accent-light);
    border-left-color: var(--accent-light);
  }

  .sidebar-link.active {
    color: var(--accent);
    background: var(--accent-light);
    border-left-color: var(--accent);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .docs-sidebar {
      z-index: 50;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      box-shadow: 2px 0 20px rgba(0, 0, 0, 0.15);
    }

    .docs-sidebar.open {
      transform: translateX(0);
    }
  }
</style>