---
import { formatDate } from '../../utils/date';

interface Props {
  title: string;
  pubDate: Date;
  author: string;
}

const { title, pubDate, author } = Astro.props;
const pageUrl = Astro.url.href;
const license = Astro.locals.site?.license;
const licenseName = license?.name ?? 'CC BY 4.0';
const licenseUrl = license?.url ?? 'https://creativecommons.org/licenses/by/4.0/';
const dateStr = formatDate(pubDate);
---

<div class="license-card">
  <div class="license-watermark">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-5.5-8c0-1.93 1.57-3.5 3.5-3.5 1.2 0 2.26.6 2.89 1.5l-1.57 1.06c-.35-.54-.92-.9-1.57-.9-1.06 0-1.92.86-1.92 1.92s.86 1.92 1.92 1.92c.65 0 1.22-.36 1.57-.9l1.57 1.06c-.63.9-1.69 1.5-2.89 1.5-1.93 0-3.5-1.57-3.5-3.5zm7 0c0-1.93 1.57-3.5 3.5-3.5 1.2 0 2.26.6 2.89 1.5l-1.57 1.06c-.35-.54-.92-.9-1.57-.9-1.06 0-1.92.86-1.92 1.92s.86 1.92 1.92 1.92c.65 0 1.22-.36 1.57-.9l1.57 1.06c-.63.9-1.69 1.5-2.89 1.5-1.93 0-3.5-1.57-3.5-3.5z"/>
    </svg>
  </div>

  <div class="license-content">
    <div class="license-title">{title}</div>
    <a href={pageUrl} class="license-url">{pageUrl}</a>

    <div class="license-meta">
      <div class="license-field">
        <span class="license-label">作者</span>
        <span class="license-value">{author}</span>
      </div>
      <div class="license-field">
        <span class="license-label">发布</span>
        <span class="license-value">{dateStr}</span>
      </div>
      <div class="license-field">
        <span class="license-label">协议</span>
        <a href={licenseUrl} target="_blank" rel="noopener" class="license-link">{licenseName}</a>
      </div>
    </div>
  </div>
</div>

<style>
  @import './LicenseCard.css';
</style>
