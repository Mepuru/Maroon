---
import { generatePath } from '../../utils/generate-path';

interface SidebarTag {
  name: string;
  count: number;
}

interface Props {
  avatar: string;
  author: string;
  bio: string;
  postsCount: number;
  tags: SidebarTag[];
  tagCount: number;
  githubUrl?: string;
}

const { avatar, author, bio, postsCount, tags, tagCount, githubUrl } = Astro.props;

const routes = Astro.locals.site?.routes;
const tagPattern = routes?.tags?.pattern ?? '/tags/[tag]';
const aboutUrl = routes?.about ?? '/about';
---

<style>
  @import './Sidebar.css';
</style>

<aside class="sidebar">
  <div class="profile-card">
    <img src={avatar} alt={author} class="profile-avatar" />
    <h3 class="profile-name">{author}</h3>
    <p class="profile-bio">{bio}</p>
    <div class="profile-stats">
      <div class="stat">
        <span class="stat-num">{postsCount}</span>
        <span class="stat-label">文章</span>
      </div>
      <div class="stat">
        <span class="stat-num">{tagCount}</span>
        <span class="stat-label">标签</span>
      </div>
    </div>
  </div>

  {tags.length > 0 && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">标签</h4>
      <div class="tag-cloud">
        {tags.map((tag) => (
          <a href={generatePath(tagPattern, { tag: tag.name })} class="tag-item">
            {tag.name}
            <span class="tag-count">{tag.count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="sidebar-section">
    <h4 class="sidebar-title">链接</h4>
    <div class="link-list">
      {githubUrl && (
        <a href={githubUrl} target="_blank" rel="noopener" class="link-item">
          GitHub
        </a>
      )}
      <a href={aboutUrl} class="link-item">
        关于我
      </a>
    </div>
  </div>
</aside>
