---
/**
 * ImageZoom — 基于 PhotoSwipe 的图片点击放大查看
 *
 * .prose 内的图片点击后打开 PhotoSwipe 灯箱，支持：
 * - 滚轮缩放
 * - 双击放大
 * - 点击/轻触关闭
 * - ViewTransitions 兼容
 */
---

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  let lightbox = null;
  let pswpModule = import('photoswipe');

  function createLightbox() {
    // 销毁旧的
    if (lightbox) {
      try { lightbox.destroy(); } catch { /* ignore */ }
    }

    const gallery = document.querySelector('.prose');
    if (!gallery) return;

    lightbox = new PhotoSwipeLightbox({
      gallery: gallery,
      children: 'img',
      pswpModule: () => pswpModule,
      padding: { top: 30, bottom: 30, left: 30, right: 30 },
      wheelToZoom: true,
      imageClickAction: 'close',
      tapAction: 'close',
      doubleTapAction: 'zoom',
      closeTitle: '关闭',
      zoomTitle: '放大',
    });

    // 从 <img> 元素读取原始尺寸
    lightbox.addFilter('domItemData', (itemData, element) => {
      if (element instanceof HTMLImageElement) {
        itemData.src = element.src;
        itemData.w = element.naturalWidth || window.innerWidth;
        itemData.h = element.naturalHeight || window.innerHeight;
        itemData.msrc = element.src;
        itemData.alt = element.alt;
      }
      return itemData;
    });

    lightbox.init();
  }

  function setup() {
    createLightbox();

    // ViewTransitions 后重建
    document.addEventListener('astro:after-swap', () => {
      createLightbox();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
</script>
