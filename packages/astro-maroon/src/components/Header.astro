---
interface NavItem {
  href: string;
  label: string;
}

interface ThemeItem {
  id: string;
  name: string;
}

interface Props {
  siteTitle: string;
  nav: NavItem[];
  themes: ThemeItem[];
}

const { siteTitle, nav, themes } = Astro.props;
const currentPath = Astro.url.pathname;
const routes = Astro.locals.site?.routes;
const homeUrl = routes?.home ?? '/';

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<style>
  @import './Header.css';
</style>

<header class="site-header">
  <div class="container header-inner">
    <a href={homeUrl} class="site-title">{siteTitle}</a>
    
    <nav class="nav-links">
      {nav.map((item) => (
        <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
      ))}
    </nav>

    <div class="nav-right">
      <button class="search-trigger" onclick="document.getElementById('search-modal').classList.add('open'); document.getElementById('search-input').focus();" aria-label="搜索">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <path d="M21 21l-4.35-4.35"/>
        </svg>
        <span class="search-text">搜索</span>
      </button>
      
      <div class="theme-switcher desktop-only">
        <button class="theme-trigger" id="theme-trigger" aria-label="切换主题">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
          </svg>
        </button>
        <div class="theme-menu" id="theme-menu">
          {themes.map(theme => (
            <button class="theme-option" data-theme={theme.id}>{theme.name}</button>
          ))}
        </div>
      </div>

      <button class="menu-trigger" id="menu-trigger" aria-label="菜单">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- 移动端菜单 -->
  <div class="mobile-menu" id="mobile-menu">
    <nav class="mobile-nav">
      {nav.map((item) => (
        <a href={item.href} class:list={[{ active: isActive(item.href) }]}>{item.label}</a>
      ))}
    </nav>
    <div class="mobile-actions">
      <div class="mobile-theme-switcher">
        {themes.map(theme => (
          <button class="theme-option" data-theme={theme.id}>{theme.name}</button>
        ))}
      </div>
    </div>
  </div>
</header>

<script>
  function initHeader() {
    // 主题切换
    const trigger = document.getElementById('theme-trigger');
    const menu = document.getElementById('theme-menu');
    if (!trigger || !menu) return;

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      menu.classList.toggle('open');
    });

    document.addEventListener('click', () => {
      menu.classList.remove('open');
    });

    menu.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest('.theme-option');
      if (!btn) return;
      const theme = (btn as HTMLElement).dataset.theme;
      if (theme) {
        document.documentElement.setAttribute('data-theme', theme);
        localStorage.setItem('theme', theme);
      }
      menu.classList.remove('open');
    });

    // 移动端菜单
    const menuTrigger = document.getElementById('menu-trigger');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!menuTrigger || !mobileMenu) return;

    menuTrigger.addEventListener('click', (e) => {
      e.stopPropagation();
      mobileMenu.classList.toggle('open');
      menuTrigger.classList.toggle('open');
    });

    document.addEventListener('click', (e) => {
      if (!mobileMenu.contains(e.target as Node) && !menuTrigger.contains(e.target as Node)) {
        mobileMenu.classList.remove('open');
        menuTrigger.classList.remove('open');
      }
    });

    // 移动端主题切换
    const mobileThemeButtons = mobileMenu.querySelectorAll('.theme-option');
    mobileThemeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const theme = (btn as HTMLElement).dataset.theme;
        if (theme) {
          document.documentElement.setAttribute('data-theme', theme);
          localStorage.setItem('theme', theme);
        }
        mobileMenu.classList.remove('open');
        menuTrigger.classList.remove('open');
      });
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>