---
interface Props {
  author: string;
  icp?: string;
  icpUrl?: string;
  themeUrl?: string;
  rssUrl?: string;
}

const { author, icp, icpUrl, themeUrl, rssUrl } = Astro.props;
---

<style>
  @import './Footer.css';
</style>

<footer class="site-footer">
  <div class="footer-copyright">
    &copy; {new Date().getFullYear()} {author} &middot;
    Powered by <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
    {themeUrl && <>&nbsp;&amp; <a href={themeUrl} target="_blank" rel="noopener">Maroon</a></>}
    {rssUrl && (
      <a href={rssUrl} class="footer-rss" target="_blank" rel="noopener" aria-label="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93v-2.83Z"/>
        </svg>
        RSS
      </a>
    )}
  </div>
  {icp && (
    <div class="footer-icp">
      <a href={icpUrl} target="_blank" rel="noopener">{icp}</a>
    </div>
  )}
</footer>
