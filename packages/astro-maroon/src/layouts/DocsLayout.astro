---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import TOC from '../components/shared/TOC.astro';
import LicenseCard from '../components/shared/LicenseCard.astro';
import PageNav from '../components/shared/PageNav.astro';
import { formatDate } from '../utils/date';

interface DocNavItem {
  slug: string;
  title: string;
}

interface DocCategory {
  name: string;
  docs: DocNavItem[];
}

interface Props {
  // BaseLayout site-wide config (optional — fallback to Astro.locals.site)
  siteTitle?: string;
  siteDescription?: string;
  nav?: Array<{ href: string; label: string }>;
  themes?: Array<{ id: string; name: string }>;
  defaultTheme?: string;
  author?: string;
  icp?: string;
  icpUrl?: string;
  // Docs-specific
  title: string;
  description?: string;
  pubDate?: Date;
  currentSlug?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
  prev?: { title: string; slug: string };
  next?: { title: string; slug: string };
  // Docs sidebar data
  categories: DocCategory[];
  totalCount: number;
  uncategorized?: DocNavItem[];
  // Empty state
  emptyTexts?: string[];
  // SEO（透传给 BaseLayout）
  image?: string;
  url?: string;
}

const {
  title, description, pubDate,
  currentSlug, headings = [], prev, next,
  categories, totalCount, uncategorized = [],
  emptyTexts = ['← 从左侧选择一篇文档'],
  image, url,
} = Astro.props;

// 截断过长的标题

const routes = Astro.locals.site?.routes;
const docsPattern = routes?.docs?.pattern ?? '/docs/[slug]';

const dateStr = pubDate ? formatDate(pubDate) : '';
const hasDoc = !!currentSlug;
const emptyText = emptyTexts[Math.floor(Math.random() * emptyTexts.length)];
const docUrl = Astro.props.url ?? Astro.url.href;
const isoDate = pubDate ? pubDate.toISOString() : '';

// SEO author — 优先取 props，其次站点配置
const docCtx = Astro.locals.site;
const siteOrigin = Astro.site?.origin ?? '';
const authorSeo = docCtx?.authorSeo ?? docCtx?.author;
const authorUrl = docCtx?.routes?.about ? `${siteOrigin}${docCtx.routes.about}` : `${siteOrigin}/about`;
---

<BaseLayout
  title={`${title} - 文档`}
  description={description}
  fullWidth={true}
  {image}
  {url}
>
  <div class="docs-page">
    <DocsSidebar
      currentSlug={currentSlug}
      categories={categories}
      totalCount={totalCount}
      uncategorized={uncategorized}
      docPattern={docsPattern}
    />

    <main class="docs-main">
      {hasDoc ? (
        <article class="doc-article">
          <header class="doc-header">
            <div class="doc-meta">
              <time class="lesson-date">{dateStr}</time>
            </div>
            <h1 class="doc-title">{title}</h1>
          </header>
          <div class="doc-content prose">
            <slot />
          </div>
          {docCtx?.license?.enable !== false && (
            <LicenseCard title={title} pubDate={pubDate!} author={docCtx?.author ?? ''} />
          )}
          <PageNav prev={prev} next={next} pattern={docsPattern} />
        </article>
      ) : (
        <div class="doc-article doc-empty">
          <p>{emptyText}</p>
        </div>
      )}
    </main>

    <aside class="toc-wrapper" id="toc-wrapper">
      <TOC headings={headings} />
    </aside>
  </div>

  <!-- 移动端：侧边栏遮罩 -->
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

  <!-- 移动端：侧边栏切换按钮 -->
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="打开目录">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <!-- 目录悬浮按钮（平板端） -->
  <button class="toc-toggle" id="toc-toggle" aria-label="切换目录">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="15" y2="12"/>
      <line x1="3" y1="18" x2="18" y2="18"/>
    </svg>
    </button>
</BaseLayout>

{hasDoc && <script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": isoDate,
  "author": {
    "@type": "Person",
    "name": authorSeo,
    "url": authorUrl
  },
  "url": docUrl,
  "image": image ?? `${siteOrigin}/icon.png`
})} />}

<style>
  .doc-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    color: var(--muted);
    font-size: 1.05rem;
    user-select: none;
    white-space: pre-line;
    text-align: center;
  }

  .doc-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--border);
  }

  .doc-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .doc-title {
    font-size: 1.75rem;
    line-height: 1.4;
    margin: 0;
  }

  .doc-content {
    line-height: 1.9;
  }

  /* ============================================
     TOC（右侧，固定于视口右边缘）
     ============================================ */
  .toc-wrapper {
    position: fixed;
    top: calc(var(--header-height) + 24px);
    right: 0.25rem;
    width: 200px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding: 1rem 1.25rem;
    border-left: 1px solid var(--border);
  }

  /* ============================================
     移动端：侧边栏遮罩
     ============================================ */
  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 45;
  }

  .sidebar-backdrop.open {
    display: block;
  }

  /* ============================================
     移动端：侧边栏切换按钮
     ============================================ */
  .sidebar-toggle {
    display: none;
    position: fixed;
    top: 76px;
    left: 1rem;
    z-index: 46;
    width: 40px;
    height: 40px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    align-items: center;
    justify-content: center;
    color: var(--fg);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: var(--accent-light);
    color: var(--accent);
  }

  /* ============================================
     TOC 悬浮按钮
     ============================================ */
  .toc-toggle {
    display: none;
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    color: var(--fg);
    cursor: pointer;
    box-shadow: var(--shadow-md);
    z-index: 210;
    transition: all 0.2s ease;
  }

  .toc-toggle:hover {
    background: var(--accent-light);
    color: var(--accent);
  }

  .toc-toggle.open {
    background: var(--accent);
    color: #fff;
  }

  /* ============================================
     响应式
     ============================================ */

  /* 平板端：隐藏 TOC */
  @media (max-width: 1200px) {
    .toc-wrapper {
      display: none;
    }

    .toc-toggle {
      display: flex;
    }
  }

  /* TOC 全屏浮层 */
  @media (max-width: 1200px) {
    .toc-wrapper.is-overlay {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 200;
      background: var(--card-bg);
      padding: 4rem 1.5rem 2rem;
      width: 100%;
      max-height: none;
      overflow-y: auto;
      border-left: none;
      border-top: 1px solid var(--border);
    }
  }

  /* 手机端：侧边栏变抽屉 */
  @media (max-width: 768px) {
    .sidebar-toggle {
      display: flex;
    }

  }
</style>

<script>
  import { initOverlayToggle } from '../utils/toc-overlay';

  let _sidebarOpen: (() => void) | null = null;
  let _sidebarClose: (() => void) | null = null;

  function initSidebarToggle() {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('docs-sidebar');
    const backdrop = document.getElementById('sidebar-backdrop');

    if (!toggle || !sidebar || !backdrop) return;

    if (_sidebarOpen) toggle.removeEventListener('click', _sidebarOpen);
    if (_sidebarClose) backdrop.removeEventListener('click', _sidebarClose);

    _sidebarOpen = () => {
      sidebar.classList.add('open');
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    };

    _sidebarClose = () => {
      sidebar.classList.remove('open');
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', _sidebarOpen);
    backdrop.addEventListener('click', _sidebarClose);

    sidebar.addEventListener('click', (e) => {
      if ((e.target as Element).closest('a')) _sidebarClose?.();
    });
  }

  initSidebarToggle();
  initOverlayToggle('toc-toggle', 'toc-wrapper');

  document.addEventListener('astro:after-swap', () => {
    initSidebarToggle();
    initOverlayToggle('toc-toggle', 'toc-wrapper');
  });
</script>
