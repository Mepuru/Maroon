---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';
import Sidebar from '../components/shared/Sidebar.astro';
import ImageZoom from '../components/shared/ImageZoom.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import '../styles/layout.css';

interface SidebarTag {
  name: string;
  count: number;
}

interface NavItem {
  href: string;
  label: string;
}

interface ThemeItem {
  id: string;
  name: string;
}

interface Props {
  // Site-wide config (all optional — fallback to Astro.locals.site)
  siteTitle?: string;
  siteDescription?: string;
  nav?: NavItem[];
  themes?: ThemeItem[];
  defaultTheme?: string;
  author?: string;
  /** SEO 署名用作者名（覆盖 author） */
  authorSeo?: string;
  icp?: string;
  icpUrl?: string;
  themeUrl?: string;
  rssUrl?: string;
  // Page-level
  title?: string;
  description?: string;
  // SEO: OG 图片 URL（绝对路径，默认 /icon.png）
  image?: string;
  /** SEO: 当前页面的规范 URL（默认自动从 site + path 拼接） */
  url?: string;
  // Sidebar (optional)
  sidebar?: boolean;
  sidebarData?: {
    avatar: string;
    author: string;
    bio: string;
    postsCount: number;
    tags: SidebarTag[];
    tagCount: number;
    githubUrl?: string;
  };
  // Layout mode
  fullWidth?: boolean;
}

// 优先级: props → Astro.locals.site（middleware 注入）→ 硬编码兜底
const ctx = Astro.locals.site;

const siteTitle = Astro.props.siteTitle ?? ctx?.title ?? '';
const siteDescription = Astro.props.siteDescription ?? ctx?.description ?? '';
const nav = Astro.props.nav ?? ctx?.nav ?? [];
const themes = Astro.props.themes ?? ctx?.themes ?? [];
const defaultTheme = Astro.props.defaultTheme ?? ctx?.defaultTheme ?? 'cream';
const author = Astro.props.author ?? ctx?.author ?? '';
const icp = Astro.props.icp ?? ctx?.footer?.icp;
const icpUrl = Astro.props.icpUrl ?? ctx?.footer?.icpUrl;
const themeUrl = Astro.props.themeUrl ?? ctx?.footer?.themeUrl;

const rssConfig = ctx?.footer?.rss;
const rssUrl = Astro.props.rssUrl ?? (rssConfig?.enable ? '/rss.xml' : undefined);

const title = Astro.props.title ?? siteTitle;
const description = Astro.props.description ?? siteDescription;
const { sidebar = false, sidebarData, fullWidth = false } = Astro.props;

const routes = Astro.locals.site?.routes;
const iconUrl = routes?.icon ?? '/favicon.svg';

// SEO: OG 图片 & 规范 URL（允许 props 覆盖）
const siteOrigin = Astro.site?.origin ?? '';
const ogImage = Astro.props.image ?? `${siteOrigin}/icon.png`;
const canonicalUrl = Astro.props.url ?? `${siteOrigin}${Astro.url.pathname}`;

// SEO author — 优先取 props，其次站点配置
const authorSeo = Astro.props.authorSeo ?? ctx?.authorSeo ?? author;
const authorUrl = routes?.about ? `${siteOrigin}${routes.about}` : `${siteOrigin}/about`;
---

<!doctype html>
<html lang="zh-CN" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={iconUrl} />

    <!-- Author & License -->
    <meta name="author" content={authorSeo} />
    <link rel="author" href={authorUrl} />
    <link rel="license" href="https://creativecommons.org/licenses/by/4.0/" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteTitle} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    {rssUrl && <link rel="alternate" type="application/rss+xml" title={siteTitle} href={rssUrl} />}

    <ViewTransitions />
    <title>{title}</title>
    <script is:inline>
      const stored = localStorage.getItem('theme');
      if (stored) document.documentElement.setAttribute('data-theme', stored);
    </script>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": authorSeo,
      "url": canonicalUrl,
      "description": description,
      "author": {
        "@type": "Person",
        "name": authorSeo,
        "url": authorUrl
      },
      "license": "https://creativecommons.org/licenses/by/4.0/",
      "copyrightHolder": {
        "@type": "Person",
        "name": authorSeo
      }
    })} />
  </head>
  <body>
    <div class="print-meta" style="display:none">{siteTitle} | {Astro.url.href}</div>
    <Header siteTitle={siteTitle} nav={nav} themes={themes} />
    <div class:list={['layout-wrapper', { wide: !sidebar, 'full-width': fullWidth }]}>
      <main class="main-content">
        <slot />
      </main>
      {sidebar && sidebarData && (
        <Sidebar
          avatar={sidebarData.avatar}
          author={sidebarData.author}
          bio={sidebarData.bio}
          postsCount={sidebarData.postsCount}
          tags={sidebarData.tags}
          tagCount={sidebarData.tagCount}
          githubUrl={sidebarData.githubUrl}
        />
      )}
    </div>
    <Footer {author} {icp} {icpUrl} {themeUrl} {rssUrl} />
    <Search />
    <ImageZoom />
    <script>
      document.addEventListener('astro:after-swap', () => {
        const theme = localStorage.getItem('theme');
        if (theme) {
          document.documentElement.setAttribute('data-theme', theme);
        }
      });

      window.addEventListener('beforeprint', () => {
        document.querySelectorAll('details').forEach(el => el.setAttribute('open', ''));
      });
      window.addEventListener('afterprint', () => {
        document.querySelectorAll('details').forEach(el => el.removeAttribute('open'));
      });
    </script>
  </body>
</html>
