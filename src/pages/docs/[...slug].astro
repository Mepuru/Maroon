---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import { getPublishedDocs } from '../../utils/content';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter((doc) => !doc.data.draft)
    .map((doc) => ({
    params: { slug: doc.id },
    props: doc,
  }));
}

type Props = Awaited<ReturnType<typeof getCollection<'docs'>>>[number];

const doc = Astro.props;
const { Content, headings } = await render(doc);

const allDocs = await getPublishedDocs();

const currentIndex = allDocs.findIndex((d) => d.id === doc.id);
const prev = currentIndex > 0 ? allDocs[currentIndex - 1] : null;
const next = currentIndex < allDocs.length - 1 ? allDocs[currentIndex + 1] : null;
---

<DocsLayout
  title={doc.data.title}
  pubDate={doc.data.pubDate}
  currentSlug={doc.id}
  headings={headings}
  prev={prev ? { title: prev.data.title, slug: prev.id } : undefined}
  next={next ? { title: next.data.title, slug: next.id } : undefined}
>
  <Content />
</DocsLayout>
