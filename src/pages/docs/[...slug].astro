---
import { getCollection, render } from 'astro:content';
import '../../styles/layout.css';
import DocsLayout from '@kurikana/astro-theme/layouts/DocsLayout.astro';
import { groupDocsByCategory } from '../../content/utils';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs
    .filter((doc) => !doc.data.draft)
    .map((doc) => ({
    params: { slug: doc.id },
    props: doc,
  }));
}

type Props = Awaited<ReturnType<typeof getCollection<'docs'>>>[number];

const doc = Astro.props;
const { Content, headings } = await render(doc);

// 加载全部文档并分组
const allDocs = await getCollection('docs');
const { publishedDocs, categories, uncategorized } = groupDocsByCategory(allDocs);

// 上下篇导航
const currentIndex = publishedDocs.findIndex((d) => d.id === doc.id);
const prev = currentIndex > 0 ? publishedDocs[currentIndex - 1] : null;
const next = currentIndex < publishedDocs.length - 1 ? publishedDocs[currentIndex + 1] : null;
---

<DocsLayout
  title={doc.data.title}
  pubDate={doc.data.pubDate}
  currentSlug={doc.id}
  headings={headings}
  prev={prev ? { title: prev.data.title, slug: prev.id } : undefined}
  next={next ? { title: next.data.title, slug: next.id } : undefined}
  categories={categories}
  totalCount={publishedDocs.length}
  uncategorized={uncategorized.map((d) => ({ slug: d.id, title: d.data.title }))}
  emptyTexts={Astro.locals.site?.docs?.emptyTexts}
>
  <Content />
</DocsLayout>