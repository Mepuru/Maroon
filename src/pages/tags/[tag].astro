---
import BaseLayout from '@kurikana/astro-theme/layouts/BaseLayout.astro';
import PostCard from '@kurikana/astro-theme/components/blog/PostCard.astro';
// 全局配置由 Astro.locals.site 注入
import { getCollection } from 'astro:content';
import '../../styles/layout.css';
import { getPublishedPosts, buildSidebarData } from '../../content/utils';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const allTags = posts.flatMap((p) => p.data.tags);
  const uniqueTags = [...new Set(allTags)];

  return uniqueTags.map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;

const publishedPosts = await getPublishedPosts();
const posts = publishedPosts.filter((p) => p.data.tags.includes(tag));

// 构造侧边栏数据
const ctx = Astro.locals.site;
const sidebarData = buildSidebarData(
  { avatar: ctx?.avatar ?? '/icon.png', author: ctx?.author ?? '', bio: ctx?.bio ?? '', social: { github: ctx?.social?.github } },
  publishedPosts,
);
---

<BaseLayout
  title={`${tag} - 栗かな的博客`}
  sidebar={true}
  sidebarData={sidebarData}
>
  <a href="/blog" class="back-link">&larr; 所有文章</a>
  <h1 class="page-title">标签：{tag}</h1>
  <p class="tag-desc">共 {posts.length} 篇文章</p>
  <div class="post-grid">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        slug={post.id}
        tags={post.data.tags}
      />
    ))}
  </div>
</BaseLayout>

<style>
  .tag-desc {
    color: var(--muted);
    margin-bottom: 1.5rem;
  }
</style>