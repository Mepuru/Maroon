---
import BaseLayout from 'astro-maroon/layouts/BaseLayout.astro';
import Hero from 'astro-maroon/components/home/Hero.astro';
import SeriesSection from 'astro-maroon/components/home/SeriesSection.astro';
import SeriesCard from 'astro-maroon/components/home/SeriesCard.astro';
import { generateSeriesConfigs } from '../content/registry';
import { getPublishedContent } from '../content/utils';
import 'astro-maroon/styles/home.css';

const seriesConfig = generateSeriesConfigs();

// 自动获取所有系列的数据
const seriesData = await Promise.all(
  seriesConfig.map(async (series) => {
    try {
      const sorted = await getPublishedContent(series.collection, {
        sortField: series.sortField,
        sortOrder: series.sortOrder,
      });

      return {
        ...series,
        count: sorted.length,
        recent: sorted.slice(0, 3).map((item) => ({
          href: `${series.link}/${item.id}`,
          title: item.data.title,
        })),
      };
    } catch {
      return {
        ...series,
        count: 0,
        recent: [],
      };
    }
  })
);

const ctx = Astro.locals.site;
const avatar = ctx?.avatar ?? '/icon.png';
const author = ctx?.author ?? '';
const bio = ctx?.bio ?? '';
---

<BaseLayout
  title="栗かな"
  description="记录生活与技术的个人博客"
>
  <div class="home-page">
    <Hero avatar={avatar} author={author} bio={bio} />
    
    <SeriesSection title="我的系列">
      {seriesData.map((series) => (
        <SeriesCard
          title={series.title}
          description={series.description}
          count={series.count}
          countLabel={series.countLabel}
          recent={series.recent}
          link={series.link}
          align={series.align}
        />
      ))}
    </SeriesSection>
  </div>
</BaseLayout>