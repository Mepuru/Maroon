---
import BaseLayout from '@kurikana/astro-theme/layouts/BaseLayout.astro';
import Hero from '@kurikana/astro-theme/components/home/Hero.astro';
import SeriesSection from '@kurikana/astro-theme/components/home/SeriesSection.astro';
import SeriesCard from '@kurikana/astro-theme/components/home/SeriesCard.astro';
import { generateSeriesConfigs } from '../content/registry';

const seriesConfig = generateSeriesConfigs();
import { getCollection } from 'astro:content';
import '@kurikana/astro-theme/styles/home.css';
import '@kurikana/astro-theme/styles/layout.css';

// 通用排序函数
function sortItems(items: any[], sortField: string, sortOrder: string) {
  return items.sort((a, b) => {
    const valueA = a.data[sortField];
    const valueB = b.data[sortField];
    
    if (sortOrder === 'desc') {
      return valueB > valueA ? 1 : valueB < valueA ? -1 : 0;
    }
    return valueA > valueB ? 1 : valueA < valueB ? -1 : 0;
  });
}

// 自动获取所有系列的数据
const seriesData = await Promise.all(
  seriesConfig.map(async (series) => {
    try {
      const collection = await getCollection(series.collection);
      const filtered = collection.filter((item) => !item.data.draft);
      const sorted = sortItems(filtered, series.sortField, series.sortOrder);

      return {
        ...series,
        count: sorted.length,
        recent: sorted.slice(0, 3),
      };
    } catch {
      return {
        ...series,
        count: 0,
        recent: [],
      };
    }
  })
);

const ctx = Astro.locals.site;
const avatar = ctx?.avatar ?? '/icon.png';
const author = ctx?.author ?? '';
const bio = ctx?.bio ?? '';
---

<BaseLayout
  title="栗かな"
  description="记录生活与技术的个人博客"
>
  <div class="home-page">
    <Hero avatar={avatar} author={author} bio={bio} />
    
    <SeriesSection title="我的系列">
      {seriesData.map((series) => (
        <SeriesCard
          title={series.title}
          description={series.description}
          count={series.count}
          countLabel={series.countLabel}
          recent={series.recent}
          link={series.link}
          align={series.align}
        />
      ))}
    </SeriesSection>
  </div>
</BaseLayout>