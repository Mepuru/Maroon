---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import SeriesSection from '../components/home/SeriesSection.astro';
import SeriesCard from '../components/home/SeriesCard.astro';
import { seriesConfig } from '../config/series';
import { getCollection } from 'astro:content';
import '../styles/home.css';

// 自动获取所有系列的数据
const seriesData = await Promise.all(
  seriesConfig.map(async (series) => {
    try {
      const collection = await getCollection(series.collection);
      const sorted = collection
        .filter((item) => !item.data.draft)
        .sort((a, b) => {
          // 博客按日期倒序，教案按周次倒序
          if (series.collection === 'blog') {
            return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
          }
          return b.data.week - a.data.week;
        });

      return {
        ...series,
        count: sorted.length,
        recent: sorted.slice(0, 3),
      };
    } catch {
      return {
        ...series,
        count: 0,
        recent: [],
      };
    }
  })
);
---

<BaseLayout title="栗かな" description="记录生活与技术的个人博客" wide={true}>
  <div class="home-page">
    <Hero />
    
    <SeriesSection title="我的系列">
      {seriesData.map((series) => (
        <SeriesCard
          title={series.title}
          description={series.description}
          count={series.count}
          countLabel={series.countLabel}
          recent={series.recent}
          link={series.link}
          align={series.align}
        />
      ))}
    </SeriesSection>
  </div>
</BaseLayout>
