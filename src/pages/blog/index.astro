---
import BaseLayout from '@kurikana/astro-theme/layouts/BaseLayout.astro';
import PostCard from '@kurikana/astro-theme/components/blog/PostCard.astro';
import { getPublishedPosts, buildSidebarData } from '../../content/utils';

const posts = await getPublishedPosts();

const ctx = Astro.locals.site;
const sidebarData = buildSidebarData(
  { avatar: ctx?.avatar ?? '', author: ctx?.author ?? '', bio: ctx?.bio ?? '', social: { github: ctx?.social?.github } },
  posts,
);
---

<BaseLayout
  title="文章 - 栗かな的博客"
  sidebar={true}
  sidebarData={sidebarData}
>
  <h1 class="page-title">所有文章</h1>
  <div class="post-grid">
    {posts.map((post) => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
        slug={post.id}
        tags={post.data.tags}
      />
    ))}
  </div>
</BaseLayout>