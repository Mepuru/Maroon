---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import TOC from '../components/shared/TOC.astro';
import { formatDate } from '../utils/date';
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  currentSlug?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
  prev?: { title: string; slug: string };
  next?: { title: string; slug: string };
}

const { title, description, pubDate, currentSlug, headings = [], prev, next } = Astro.props;

const dateStr = pubDate ? formatDate(pubDate) : '';
const hasDoc = !!currentSlug;
const emptyText = siteConfig.docs.emptyTexts[Math.floor(Math.random() * siteConfig.docs.emptyTexts.length)];
---

  <BaseLayout title={`${title} - 文档`} description={description}>
  <div class="docs-page">
    <DocsSidebar currentSlug={currentSlug} />

    <main class="docs-main">
      {hasDoc ? (
        <article class="doc-article">
          <header class="doc-header">
            <div class="doc-meta">
              <time class="lesson-date">{dateStr}</time>
            </div>
            <h1 class="doc-title">{title}</h1>
          </header>
          <div class="doc-content prose">
            <slot />
          </div>
          {(prev || next) && (
            <nav class="doc-nav">
              {prev ? (
                <a href={`/docs/${prev.slug}`} class="doc-nav-link">
                  <span class="doc-nav-label">&larr; 上一篇</span>
                  <span class="doc-nav-title">{prev.title}</span>
                </a>
              ) : <span />}
              {next ? (
                <a href={`/docs/${next.slug}`} class="doc-nav-link doc-nav-next">
                  <span class="doc-nav-label">下一篇 &rarr;</span>
                  <span class="doc-nav-title">{next.title}</span>
                </a>
              ) : <span />}
            </nav>
          )}
        </article>
      ) : (
        <div class="doc-article doc-empty">
          <p>{emptyText}</p>
        </div>
      )}
    </main>

    <aside class="toc-wrapper" id="toc-wrapper">
      <TOC headings={headings} />
    </aside>
  </div>

  <!-- 移动端：侧边栏遮罩 -->
  <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

  <!-- 移动端：侧边栏切换按钮 -->
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="打开目录">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>

  <!-- 目录悬浮按钮（平板端） -->
  <button class="toc-toggle" id="toc-toggle" aria-label="切换目录">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="15" y2="12"/>
      <line x1="3" y1="18" x2="18" y2="18"/>
    </svg>
  </button>
</BaseLayout>

<style>
  :global(.layout-wrapper) {
    max-width: none;
    margin: 0;
    padding: 0;
  }

  .docs-page {
    min-height: calc(100vh - 64px);
  }

  .docs-main {
    margin-left: 260px;
    margin-right: 200px;
    padding: 2rem 3rem 2rem 1.5rem;
    min-width: 0;
  }

  .doc-article {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
  }

  .doc-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    color: var(--muted);
    font-size: 1.05rem;
    user-select: none;
    white-space: pre-line;
    text-align: center;
  }

  .doc-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--border);
  }

  .doc-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .doc-title {
    font-size: 1.75rem;
    line-height: 1.4;
    margin: 0;
  }

  .doc-content {
    line-height: 1.9;
  }

  .doc-nav {
    display: flex;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .doc-nav-link {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .doc-nav-link:hover {
    border-color: var(--accent);
    background: var(--accent-light);
  }

  .doc-nav-next {
    text-align: right;
  }

  .doc-nav-label {
    font-size: 0.8rem;
    color: var(--muted);
  }

  .doc-nav-title {
    font-size: 0.9rem;
    color: var(--fg);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ============================================
     TOC（右侧，固定于视口右边缘）
     ============================================ */
  .toc-wrapper {
    position: fixed;
    top: 88px;
    right: 0.25rem;
    width: 200px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
    padding: 1rem 1.25rem;
    border-left: 1px solid var(--border);
  }

  /* ============================================
     移动端：侧边栏遮罩
     ============================================ */
  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 45;
  }

  .sidebar-backdrop.open {
    display: block;
  }

  /* ============================================
     移动端：侧边栏切换按钮
     ============================================ */
  .sidebar-toggle {
    display: none;
    position: fixed;
    top: 76px;
    left: 1rem;
    z-index: 46;
    width: 40px;
    height: 40px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    align-items: center;
    justify-content: center;
    color: var(--fg);
    cursor: pointer;
    box-shadow: var(--shadow-sm);
    transition: background 0.2s ease;
  }

  .sidebar-toggle:hover {
    background: var(--accent-light);
    color: var(--accent);
  }

  /* ============================================
     TOC 悬浮按钮
     ============================================ */
  .toc-toggle {
    display: none;
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    color: var(--fg);
    cursor: pointer;
    box-shadow: var(--shadow-md);
    z-index: 210;
    transition: all 0.2s ease;
  }

  .toc-toggle:hover {
    background: var(--accent-light);
    color: var(--accent);
  }

  .toc-toggle.open {
    background: var(--accent);
    color: #fff;
  }

  /* ============================================
     响应式
     ============================================ */

  /* 平板端：隐藏 TOC */
  @media (max-width: 1200px) {
    .docs-main {
      margin-right: 0;
    }

    .toc-wrapper {
      display: none;
    }

    .toc-toggle {
      display: flex;
    }
  }

  /* TOC 全屏浮层 */
  @media (max-width: 1200px) {
    .toc-wrapper.is-overlay {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 200;
      background: var(--card-bg);
      padding: 4rem 1.5rem 2rem;
      width: 100%;
      max-height: none;
      overflow-y: auto;
      border-left: none;
      border-top: 1px solid var(--border);
    }
  }

  /* 手机端：侧边栏变抽屉 */
  @media (max-width: 768px) {
    .docs-main {
      margin-left: 0;
      padding: 1.5rem 1rem;
    }

    .sidebar-toggle {
      display: flex;
    }
  }
</style>

<script>
  let _sidebarOpen: (() => void) | null = null;
  let _sidebarClose: (() => void) | null = null;
  let _tocClick: (() => void) | null = null;
  let _tocDocClick: ((e: Event) => void) | null = null;

  function initSidebarToggle() {
    const toggle = document.getElementById('sidebar-toggle');
    const sidebar = document.getElementById('docs-sidebar');
    const backdrop = document.getElementById('sidebar-backdrop');

    if (!toggle || !sidebar || !backdrop) return;

    if (_sidebarOpen) toggle.removeEventListener('click', _sidebarOpen);
    if (_sidebarClose) backdrop.removeEventListener('click', _sidebarClose);

    _sidebarOpen = () => {
      sidebar.classList.add('open');
      backdrop.classList.add('open');
      document.body.style.overflow = 'hidden';
    };

    _sidebarClose = () => {
      sidebar.classList.remove('open');
      backdrop.classList.remove('open');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', _sidebarOpen);
    backdrop.addEventListener('click', _sidebarClose);

    sidebar.addEventListener('click', (e) => {
      if ((e.target as Element).closest('a')) _sidebarClose?.();
    });
  }

  function initTocToggle() {
    const toggle = document.getElementById('toc-toggle');
    const wrapper = document.getElementById('toc-wrapper');

    if (!toggle || !wrapper) return;

    if (_tocClick) toggle.removeEventListener('click', _tocClick);
    if (_tocDocClick) document.removeEventListener('click', _tocDocClick);

    _tocClick = () => {
      wrapper.classList.toggle('is-overlay');
      toggle.classList.toggle('open');
    };

    _tocDocClick = (e) => {
      if (!wrapper.contains(e.target as Node) && !toggle.contains(e.target as Node)) {
        wrapper.classList.remove('is-overlay');
        toggle.classList.remove('open');
      }
    };

    toggle.addEventListener('click', _tocClick);
    document.addEventListener('click', _tocDocClick);
  }

  initSidebarToggle();
  initTocToggle();

  document.addEventListener('astro:after-swap', () => {
    initSidebarToggle();
    initTocToggle();
  });
</script>
