---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/shared/TOC.astro';
import type { PostData } from '../types';
import { formatDate } from '../utils/date';

type Props = PostData & {
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
};

const { title, description, pubDate, tags = [], readingTime, headings = [] } = Astro.props;

const dateStr = formatDate(pubDate);
---

<BaseLayout title={`${title} - 栗かな的博客`} description={description} sidebar={true}>
  <div class="post-page">
    <article class="post-article">
      <a href="/blog" class="back-link">&larr; 返回文章列表</a>
      <header class="post-header">
        <h1>{title}</h1>
        <div class="post-meta">
          <time>{dateStr}</time>
          {readingTime && <span>阅读大约需要 {readingTime} 分钟</span>}
          {tags.length > 0 && (
            <div class="tags">
              {tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>

    {headings.length > 0 && <TOC headings={headings} />}
  </div>
</BaseLayout>

<style>
  .post-page {
    display: flex;
    gap: 2rem;
  }

  .post-article {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 1200px) {
    .post-page {
      flex-direction: column;
    }
  }
</style>
