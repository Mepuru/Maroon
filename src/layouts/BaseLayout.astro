---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Search from '../components/Search.astro';
import Sidebar from '../components/shared/Sidebar.astro';
import { ViewTransitions } from 'astro:transitions';
import { defaultTheme } from '../utils/themes';
import { defaultTitle, defaultDescription } from '../config/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  sidebar?: boolean;
}

const { title = defaultTitle, description = defaultDescription, sidebar = false } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" data-theme={defaultTheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ViewTransitions />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem('theme') || 'cream';
      document.documentElement.setAttribute('data-theme', theme);
    </script>
  </head>
  <body>
    <div class="print-meta" style="display:none">栗かな | {Astro.url.href}</div>
    <Header />
    <div class:list={['layout-wrapper', { wide: !sidebar }]}>
      <main class="main-content">
        <slot />
      </main>
      {sidebar && <Sidebar />}
    </div>
    <Footer />
    <Search />
    <script>
      document.addEventListener('astro:after-swap', () => {
        const theme = localStorage.getItem('theme');
        if (theme) {
          document.documentElement.setAttribute('data-theme', theme);
        }
      });
    </script>
  </body>
</html>
