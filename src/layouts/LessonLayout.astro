---
import BaseLayout from './BaseLayout.astro';
import LessonSidebar from '../components/lessons/LessonSidebar.astro';
import TOC from '../components/shared/TOC.astro';

interface Props {
  title: string;
  description?: string;
  date: Date;
  currentSlug?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { title, description, date, currentSlug, headings = [] } = Astro.props;

const dateStr = date.toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
});
---

<BaseLayout title={`${title} - 日语教案`} description={description}>
  <div class="lessons-page">
    <LessonSidebar currentSlug={currentSlug} />

    <main class="lessons-main">
      <article class="lesson">
        <header class="lesson-header">
          <div class="lesson-meta">
            <time class="lesson-date">{dateStr}</time>
          </div>
          <h1 class="lesson-title">{title}</h1>
        </header>
        <div class="lesson-content prose">
          <slot />
        </div>
      </article>
    </main>

    <div class="toc-wrapper">
      <button class="toc-toggle" id="toc-toggle" aria-label="切换目录">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="15" y2="12"/>
          <line x1="3" y1="18" x2="18" y2="18"/>
        </svg>
      </button>
      <div class="toc-container" id="toc-container">
        <TOC headings={headings} />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .lessons-page {
    display: grid;
    grid-template-columns: 200px 1fr 200px;
    min-height: calc(100vh - 64px);
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .lessons-main {
    min-width: 0;
    display: flex;
    justify-content: center;
    padding: 2rem 3rem;
  }

  .lesson {
    width: 100%;
    max-width: 1000px;
  }

  .lesson-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px dashed var(--border);
  }

  .lesson-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }

  .lesson-title {
    font-size: 1.75rem;
    line-height: 1.4;
    margin: 0;
  }

  .lesson-content {
    line-height: 1.9;
  }

  .toc-wrapper {
    position: relative;
  }

  .toc-toggle {
    display: none;
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 48px;
    height: 48px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 50%;
    align-items: center;
    justify-content: center;
    color: var(--fg);
    cursor: pointer;
    box-shadow: var(--shadow-md);
    z-index: 100;
    transition: all 0.2s ease;
  }

  .toc-toggle:hover {
    background: var(--accent-light);
    color: var(--accent);
  }

  .toc-toggle.open {
    background: var(--accent);
    color: #fff;
  }

  .toc-container {
    position: sticky;
    top: 88px;
    width: 200px;
  }

  /* 平板端：隐藏 TOC */
  @media (max-width: 1200px) {
    .lessons-page {
      grid-template-columns: 200px 1fr;
      padding: 0 1.5rem;
    }

    .toc-container {
      display: none;
    }

    .toc-toggle {
      display: flex;
    }
  }

  /* 手机端：隐藏侧边栏 */
  @media (max-width: 768px) {
    .lessons-page {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }

    .lessons-main {
      padding: 1.5rem 0;
    }

    .toc-container {
      display: none;
      position: fixed;
      top: 80px;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--card-bg);
      border-top: 1px solid var(--border);
      padding: 1.5rem;
      overflow-y: auto;
      z-index: 99;
      width: 100%;
    }

    .toc-container.open {
      display: block;
    }
  }
</style>

<script>
  // 手机端目录切换
  function initTocToggle() {
    const toggle = document.getElementById('toc-toggle');
    const container = document.getElementById('toc-container');

    if (!toggle || !container) return;

    toggle.addEventListener('click', () => {
      container.classList.toggle('open');
      toggle.classList.toggle('open');
    });

    // 点击其他地方关闭
    document.addEventListener('click', (e) => {
      if (!container.contains(e.target) && !toggle.contains(e.target)) {
        container.classList.remove('open');
        toggle.classList.remove('open');
      }
    });
  }

  // 页面加载时初始化
  initTocToggle();

  // 页面切换时重新初始化
  document.addEventListener('astro:after-swap', initTocToggle);
</script>
