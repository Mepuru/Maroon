---
import { siteConfig } from '../config/site';
---

<style>
  @import './Footer.css';
</style>

<footer class="site-footer">
  <div>
    &copy; {new Date().getFullYear()} {siteConfig.author} &middot; Powered by Astro
  </div>
  {siteConfig.footer.icp && (
    <div class="footer-icp">
      <a href={siteConfig.footer.icpUrl} target="_blank" rel="noopener">{siteConfig.footer.icp}</a>
    </div>
  )}
</footer>
