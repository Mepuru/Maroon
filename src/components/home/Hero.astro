---
import { siteConfig } from '../../config/site';
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-avatar">
      <img src={siteConfig.avatar} alt={siteConfig.author} />
    </div>
    <div class="hero-text">
      <h1 class="hero-title">Hi, 我是{siteConfig.author}</h1>
      <p class="hero-subtitle">{siteConfig.bio}</p>
      <a href="/about" class="hero-link">了解更多 →</a>
    </div>
  </div>
</section>

<style>
  @import './Hero.css';
</style>
