---
// 单个系列卡片组件
interface RecentItem {
  id: string;
  data: {
    title: string;
  };
}

interface Props {
  title: string;
  description: string;
  count: number;
  countLabel: string;
  recent: RecentItem[];
  link: string;
  align?: 'left' | 'right';
}

const { title, description, count, countLabel, recent, link, align = 'left' } = Astro.props;
---

<article class:list={['series-card', `align-${align}`]}>
  <div class="card-header">
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <div class="card-stats">
      <span class="stats-number">{count}</span>
      <span class="stats-label">{countLabel}</span>
    </div>
  </div>

  <div class="card-divider"></div>

  <div class="card-recent">
    <h4 class="recent-title">最近更新</h4>
    <ul class="recent-list">
      {recent.map((item) => (
        <li class="recent-item">
          <a href={`${link}/${item.id}`}>{item.data.title}</a>
        </li>
      ))}
    </ul>
  </div>

  <a href={link} class="card-link">进入 →</a>
</article>

<style>
  @import './SeriesCard.css';
</style>
