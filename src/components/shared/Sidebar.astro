---
import { getCollection } from 'astro:content';
import { siteConfig } from '../../config/site';

let postsCount = 0;
let sortedTags: [string, number][] = [];

try {
  const posts = await getCollection('blog');
  postsCount = posts.length;
  const allTags = posts.flatMap((p) => p.data.tags);
  const tagCounts = allTags.reduce((acc, tag) => {
    acc[tag] = (acc[tag] || 0) + 1;
    return acc;
  }, {} as Record<string, number>);
  sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
} catch {
  // 数据加载失败时显示空状态
}
---

<style>
  @import './Sidebar.css';
</style>

<aside class="sidebar">
  <div class="profile-card">
    <img src={siteConfig.avatar} alt={siteConfig.author} class="profile-avatar" />
    <h3 class="profile-name">{siteConfig.author}</h3>
    <p class="profile-bio">{siteConfig.bio}</p>
    <div class="profile-stats">
      <div class="stat">
        <span class="stat-num">{postsCount}</span>
        <span class="stat-label">文章</span>
      </div>
      <div class="stat">
        <span class="stat-num">{sortedTags.length}</span>
        <span class="stat-label">标签</span>
      </div>
    </div>
  </div>

  {sortedTags.length > 0 && (
    <div class="sidebar-section">
      <h4 class="sidebar-title">标签</h4>
      <div class="tag-cloud">
        {sortedTags.map(([tag, count]) => (
          <a href={`/tags/${encodeURIComponent(tag)}`} class="tag-item">
            {tag}
            <span class="tag-count">{count}</span>
          </a>
        ))}
      </div>
    </div>
  )}

  <div class="sidebar-section">
    <h4 class="sidebar-title">链接</h4>
    <div class="link-list">
      {siteConfig.social.github && (
        <a href={siteConfig.social.github} target="_blank" rel="noopener" class="link-item">
          GitHub
        </a>
      )}
      <a href="/about" class="link-item">
        关于我
      </a>
    </div>
  </div>
</aside>
